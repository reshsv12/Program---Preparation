#include <stdio.h>

int isBalanced(char *str) {
    char stack[100];
    int top = -1;

    for (int i = 0; str[i] != '\0'; i++) {
        char a = str[i];
        if (a == '{' || a == '(' || a == '[') {
            stack[++top] = a;
        }
        else if (a == '}' || a == ')' || a == ']') {
            if (top == -1) 
                return 0;
            if ((a == '}' && stack[top] != '{') ||(a == ')' && stack[top] != '(') || (a == ']' && stack[top] != '[')) {
                return 0; 
            }
            top--; 
        }
    }
    return top == -1; 
}

int main() {
    char in[] = "{{}}{)([][]";
    if (isBalanced(in)) {
        printf("Balanced\n");
    } 
    else{
        printf("Not Balanced\n");
    }
    return 0;
}
