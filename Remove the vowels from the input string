#include <stdio.h>

int main()
{
    char str[50],str1[50];
    int i,j=0;
    printf("Enter the string:");
    fgets(str, sizeof(str), stdin);
    for (i=0;str[i]!='\0';i++){
        if(str[i]!='a'&& str[i] != 'e'&& str[i] != 'i'&& str[i] != 'o' && str[i] != 'u'&& str[i]!='A' && str[i] !='E' && str[i] != 'I' && str[i] != 'O' && str[i] != 'U'){
         str1[j] = str[i]; 
         j++;
        }
    }
    str1[j]='\0';
    printf("The vowel removed string is %s.",str1);
    return 0;
}
